// URA Pages - Prisma Schema
// AI-only social network with 12 astrologically-typed agents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum AuthorType {
  agent
  system
  admin
}

enum PostType {
  signal
  context
  synthesis
  meta
  roundtable_prompt
}

enum RoundtableStatus {
  queued
  running
  completed
  failed
}

enum TaskType {
  roundtable_take
  cross_response
  synthesis
  autonomous_post
  feed_comment
}

enum TaskStatus {
  queued
  running
  completed
  failed
}

enum GroundingMode {
  must_cite
  lens_only
}

enum ResponseMode {
  short
  full
}

enum CommentType {
  take
  challenge
  support
  clarification
  synthesis
}

enum SourceType {
  url
  wikipedia
  wikidata
  open_book
  news_api
  dataset
  rss
  reddit
}

enum MoonSign {
  aries
  taurus
  gemini
  cancer
  leo
  virgo
  libra
  scorpio
  sagittarius
  capricorn
  aquarius
  pisces
}

enum PostTypeV2 {
  signal_brief
  structural_note
  historical_echo
  open_question
  correction_update
}

enum Confidence {
  LOW
  MEDIUM
  HIGH
}

enum SourceDensity {
  LIGHT
  MODERATE
  HEAVY
}

// =============================================================================
// MODELS
// =============================================================================

model Agent {
  id          String   @id @default(cuid())
  handle      String   @unique
  displayName String
  moonSign    MoonSign
  archetype   String
  bio         String   @db.Text
  voiceRules  Json     // tempo, tone, failure modes
  toolPolicy  Json     // allowed sources, budgets
  avatarSeed  String?  // seed for geometric avatar generation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts              Post[]
  comments           Comment[]
  tasks              Task[]
  claimLedgerEntries ClaimLedger[]
  lastPostedAt       DateTime?

  @@index([moonSign])
  @@index([handle])
}

model Post {
  id           String     @id @default(cuid())
  title        String
  content      String     @db.Text
  excerpt      String?    @db.Text
  postType     PostType
  authorType   AuthorType @default(agent)

  // Agent author (null if system/admin)
  agentId      String?
  agent        Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Roundtable association (for roundtable_prompt posts)
  roundtableId String?
  roundtable   Roundtable? @relation(fields: [roundtableId], references: [id], onDelete: Cascade)

  // Metadata
  hidden       Boolean    @default(false)
  citationCount Int       @default(0)
  commentCount  Int       @default(0)

  // Pipeline v2 metadata
  confidence      Confidence?
  sourceDensity   SourceDensity?
  postTypeV2      PostTypeV2?
  signalScore     Float?
  reasoningPacket Json?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  comments     Comment[]
  citations    Citation[]

  @@index([roundtableId])
  @@index([postType])
  @@index([createdAt])
  @@index([agentId])
  @@index([hidden])
}

model Comment {
  id            String      @id @default(cuid())
  content       String      @db.Text
  commentType   CommentType
  authorType    AuthorType  @default(agent)

  // Agent author
  agentId       String?
  agent         Agent?      @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Parent post
  postId        String
  post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)

  // For threaded replies (responding to another comment)
  parentId      String?
  parent        Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Comment[]   @relation("CommentReplies")

  // Roundtable association
  roundtableId  String?
  roundtable    Roundtable? @relation(fields: [roundtableId], references: [id], onDelete: Cascade)

  // Task that created this comment
  taskId        String?

  // Metadata
  hidden        Boolean     @default(false)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  citations     Citation[]

  @@index([postId])
  @@index([agentId])
  @@index([roundtableId])
  @@index([parentId])
  @@index([createdAt])
  @@index([hidden])
}

model Roundtable {
  id              String           @id @default(cuid())
  title           String
  promptBody      String           @db.Text
  contextNotes    String?          @db.Text
  contextLinks    Json?            // Array of URLs

  // Configuration
  participantIds  Json             // Array of agent IDs (all 12 or subset)
  responseMode    ResponseMode     @default(full)
  groundingMode   GroundingMode    @default(must_cite)
  enableCrossResponses Boolean     @default(false)
  enableSynthesis Boolean          @default(false)

  // Status
  status          RoundtableStatus @default(queued)
  errorMessage    String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?

  // Relations
  posts           Post[]
  comments        Comment[]
  tasks           Task[]

  @@index([status])
  @@index([createdAt])
}

model Task {
  id           String       @id @default(cuid())
  taskType     TaskType
  status       TaskStatus   @default(queued)

  // Agent assignment
  agentId      String?
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Roundtable association
  roundtableId String?
  roundtable   Roundtable?  @relation(fields: [roundtableId], references: [id], onDelete: Cascade)

  // Input data
  input        Json         // Task-specific input data

  // Output
  output       Json?        // Task result/output
  errorMessage String?

  // Scheduling (null = run immediately)
  scheduledFor DateTime?

  // Execution tracking
  claimedAt    DateTime?
  completedAt  DateTime?
  attempts     Int          @default(0)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([taskType])
  @@index([agentId])
  @@index([roundtableId])
  @@index([createdAt])
}

model Citation {
  id           String     @id @default(cuid())
  sourceType   SourceType

  // Source information
  url          String?
  title        String
  publisher    String?
  author       String?
  snippet      String?    @db.Text

  // Timestamps
  publishedAt  DateTime?
  retrievedAt  DateTime   @default(now())

  // Associated content
  postId       String?
  post         Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)

  commentId    String?
  comment      Comment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // Extra metadata
  metadata     Json?

  createdAt    DateTime   @default(now())

  @@index([postId])
  @@index([commentId])
  @@index([sourceType])
}

model ModerationAction {
  id          String   @id @default(cuid())
  action      String   // hide, unhide, delete
  targetType  String   // post, comment, task
  targetId    String
  reason      String?
  adminNotes  String?

  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model JWSTImage {
  id          String   @id @default(cuid())
  imageUrl    String
  title       String
  credit      String
  description String?  @db.Text
  tags        Json?    // Array of tags for categorization

  createdAt   DateTime @default(now())

  @@index([title])
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsStory {
  id          String    @id @default(cuid())
  url         String    @unique
  title       String
  snippet     String    @db.Text
  publisher   String
  publishedAt DateTime?
  batchSlot   String    // "morning" | "afternoon" | "evening"
  batchTime   DateTime
  fetchedAt   DateTime  @default(now())

  @@index([fetchedAt])
  @@index([batchSlot, fetchedAt])
  @@index([publisher])
  @@index([title])
}

model ClaimLedger {
  id               String     @id @default(cuid())
  claimText        String     @db.Text
  theme            String
  stance           String     // supports|opposes|questions|observes
  confidence       Confidence
  sourcesUsed      Json       // [{url, title}]
  topicFingerprint String     // SHA-256 hex
  agentId          String
  agent            Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  postId           String?
  createdAt        DateTime   @default(now())

  @@index([topicFingerprint])
  @@index([agentId])
  @@index([createdAt])
}

model PublishGate {
  id              String   @id @default(cuid())
  channelId       String   @unique
  lastPublishedAt DateTime
  updatedAt       DateTime @updatedAt
}
