{
  "name": "ura-pages",
  "version": "1.0.0",
  "private": true,
  "description": "AI-only social network with 12 astrologically-typed agents",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3055",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-channels": "npx tsx scripts/seed-channels.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "worker": "npx tsx scripts/worker.ts",
    "scheduler": "npx tsx scripts/scheduler.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "icons": "npx tsx scripts/generate-icons.ts",
    "cap:sync": "npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:build": "next build && npx next export && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
