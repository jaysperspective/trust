# Database
DATABASE_URL="postgresql://user:password@localhost:5432/urapages?schema=public"

# Authentication
# Admin password - change this in production!
ADMIN_PASSWORD="6venussix"
# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# LLM Provider Configuration
# Supported: openai, anthropic
LLM_PROVIDER="openai"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo-preview"

# Anthropic Configuration (alternative)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# Cron job secret (for protected API routes)
CRON_SECRET="your-cron-secret-here"

# Astro Service URL (Swiss Ephemeris microservice for planet positions)
# If not set, astrology section will show "unavailable" gracefully
ASTRO_SERVICE_URL="http://127.0.0.1:3002"

# Optional: News API key (for news provider)
# If not set, falls back to RSS feeds
NEWS_API_KEY=""

# Optional: Wikipedia User-Agent (recommended)
WIKIPEDIA_USER_AGENT="URAPages/1.0 (https://github.com/your-repo; your-email@example.com)"
