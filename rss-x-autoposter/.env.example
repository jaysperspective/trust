# ===========================================
# RSS-X-AUTOPOSTER CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# ----- X (Twitter) API Credentials -----
# OAuth 1.0a User Context credentials
# Get these from https://developer.x.com/en/portal/dashboard
X_API_KEY=your_consumer_api_key
X_API_SECRET=your_consumer_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_token_secret

# ----- RSS Feed URLs -----
# The two RSS feeds to poll
FEED_NEWSROOM_URL=https://example.com/newsroom/feed.xml
FEED_LATEST_URL=https://example.com/latest/feed.xml

# ----- Base Public URL -----
# Used to replace localhost URLs in feeds with production URLs
# If your RSS feed contains localhost:3000 links, they will be replaced with this
BASE_PUBLIC_URL=https://plusntrust.org

# ----- Polling & Rate Limits -----
# How often to poll feeds (in seconds)
POLL_INTERVAL_SEC=300

# Maximum new items to queue per feed per poll cycle
# Prevents spam bursts if feed suddenly has many new items
MAX_NEW_ITEMS_PER_FEED_PER_POLL=3

# Minimum delay between posting separate items/threads (in seconds)
# X rate limits: ~50 tweets per 24h for free tier
MIN_DELAY_BETWEEN_POSTS_SEC=90

# Global throttle: minimum time between stories across BOTH feeds (in seconds)
# Default 3600 = one story per hour. Set to 0 to disable.
MIN_TIME_BETWEEN_STORIES_SEC=3600

# Maximum retry attempts for failed posts
MAX_RETRIES=5

# ----- Thread Mode -----
# Thread posting mode:
#   "off"     - Single tweet per item (default): [SOURCE] Title + link
#   "summary" - Thread with bullet points: title, summary bullets, link
#   "full"    - Thread with full article: title, content chunks, link
THREAD_MODE=off

# Maximum tweets per thread (1-25)
THREAD_MAX_TWEETS=8

# Whether to append the article link as the final tweet
THREAD_APPEND_LINK_LAST=true

# First tweet prefix mode: "tag" includes [SOURCE], "none" omits it
THREAD_FIRST_TWEET_PREFIX_MODE=tag

# Delay between tweets when posting a thread (in seconds)
# This is separate from MIN_DELAY_BETWEEN_POSTS_SEC which controls delay between items
THREAD_DELAY_BETWEEN_TWEETS_SEC=10

# ----- Operation Mode -----
# Set to true to log tweets without actually posting
DRY_RUN=false

# ----- HTTP Server -----
# Port for health check endpoint
PORT=3100

# ----- Optional: Hashtags -----
# Comma-separated hashtags to append to tweets (optional)
# Only applies to single-tweet mode (THREAD_MODE=off)
# Example: #URA,#News,#AI
HASHTAGS=

# ----- Timezone -----
# Timezone for logging (default: UTC)
TIMEZONE=UTC
