# ===========================================
# RSS-X-AUTOPOSTER CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# ----- X (Twitter) API Credentials -----
# OAuth 1.0a User Context credentials
# Get these from https://developer.x.com/en/portal/dashboard
X_API_KEY=your_consumer_api_key
X_API_SECRET=your_consumer_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_token_secret

# ----- RSS Feed URLs -----
# The two RSS feeds to poll
FEED_NEWSROOM_URL=https://example.com/newsroom/feed.xml
FEED_LATEST_URL=https://example.com/latest/feed.xml

# ----- Polling & Rate Limits -----
# How often to poll feeds (in seconds)
POLL_INTERVAL_SEC=300

# Maximum new items to queue per feed per poll cycle
# Prevents spam bursts if feed suddenly has many new items
MAX_NEW_ITEMS_PER_FEED_PER_POLL=3

# Minimum delay between posting tweets (in seconds)
# X rate limits: ~50 tweets per 24h for free tier
MIN_DELAY_BETWEEN_POSTS_SEC=90

# Maximum retry attempts for failed posts
MAX_RETRIES=5

# ----- Operation Mode -----
# Set to true to log tweets without actually posting
DRY_RUN=false

# ----- HTTP Server -----
# Port for health check endpoint
PORT=3100

# ----- Optional: Hashtags -----
# Comma-separated hashtags to append to tweets (optional)
# Example: #URA,#News,#AI
HASHTAGS=

# ----- Timezone -----
# Timezone for logging (default: UTC)
TIMEZONE=UTC
